# ----------------------------------------
# | STRUCTURE MODULE
# ----------------------------------------

# ----------------------------------------
# | ERROS TRATAMENTS -> prod :: dev
# ----------------------------------------
APP_ENV=prod
APP_DEBUG=false
APP_ROUTE_CACHE=false
APP_TRUST_PROXY=false
# Testes locais: true = energia infinita (sem gasto em start/tick)
APP_INFINITE_ENERGY=false

# ----------------------------------------
# | CACHE
# ----------------------------------------
CACHE_KEY=""
CACHE_DEFAULT_TTL=3600
CACHE_TTL_HOT=15
CACHE_TTL_SHORT=60
CACHE_TTL_MEDIUM=300
CACHE_TTL_LONG=3600
CACHE_TTL_STATIC=86400

# ----------------------------------------
# | REQUEST PROTECTION
# ----------------------------------------
RATE_LIMIT_MAX_ATTEMPTS=120
RATE_LIMIT_DECAY_SECONDS=60
REQUEST_MAX_BODY_BYTES=1048576
SIGNED_REQUESTS_ENABLED=false
SIGNED_REQUEST_TTL_SECONDS=120
SIGNED_REQUEST_NONCE_TTL_SECONDS=300
IDEMPOTENCY_TTL_SECONDS=86400
IDEMPOTENCY_HEADER=Idempotency-Key
IDEMPOTENCY_DRIVER=database
IDEMPOTENCY_TABLE=idempotency_keys
AUDIT_DRIVER=database
AUDIT_TABLE=game_audit_logs
AUDIT_FALLBACK_TO_FILE=true
SESSION_NAME=GBSESSID
SESSION_LIFETIME=0
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=Lax
SESSION_STRICT_MODE=true
SSE_ALLOWED_ORIGINS=
SSE_MAX_SECONDS=120
SSE_HEARTBEAT_SECONDS=15

# ----------------------------------------
# | LOCALIZATION
# ----------------------------------------
APP_TIMEZONE=America/Sao_Paulo

# ----------------------------------------
# | Default structure folders
# ----------------------------------------
DEFAULT_DASHBOARD_CONTENT=dashboard
DEFAULT_WEBSITE_CONTENT=website

# ----------------------------------------
# | Default files Structure
# ----------------------------------------
MOD_INDEX_FILE="index.php"
MOD_JSON_FILE="module.json"
MODULE_CACHE_TTL=3600
MODULE_ALLOWED_EXTERNAL_HOSTS=

# ----------------------------------------
# | Default structure
# ----------------------------------------
DEFAULT_DOMINIO="localhost"
DEFAULT_SYSTEM_CONTENT=app

# ----------------------------------------
# | GLOBAL Variables
# ----------------------------------------
DEFAULT_TITLE="System Title"
DEFAULT_VERSION=1.0.0
DEFAULT_LANG=pt-br
DEFAULT_CHARSET=utf-8

# ----------------------------------------
# | Error Pages
# ----------------------------------------
MOD_ERROR_400=400
MOD_ERROR_404=404
MOD_ERROR_500=500
MOD_ERROR_502=502

# ----------------------------------------
# | DB Global Variabels
# ----------------------------------------
DB_PROD_HOST=127.0.0.1
DB_PROD_PORT=3306
DB_PROD_USERNAME=root
DB_PROD_PASSWORD=
DB_PROD_DBNAME=

DB_DEV_HOST=127.0.0.1
DB_DEV_PORT=3306
DB_DEV_USERNAME=root
DB_DEV_PASSWORD=
DB_DEV_DBNAME=

# -------------------
# | SECURITY MODULE |
# -------------------

# ----------------------------------------
# OPEN_SSL KEY
# ----------------------------------------
MASTER_KEY=""

# ----------------------------------------
# OPEN_SSL KEY - SCRIPT
# ----------------------------------------
MASTER_SCRIPT_KEY=""

# ----------------------------------------
# JWT VARS
# ----------------------------------------
JWT_KEY=""
JWT_EXP=7
JWT_REFRESH_EXP=30

# --------------
# | API MODULE |
# --------------

# ----------------------------------------
# CLOUDINARY WEBHOOKS
# ----------------------------------------
CLOUDINARY_URL=
CLOUDINARY_DEFAULT_FOLDER=gitbook
CLOUDINARY_MAX_SIZE_MB=5
CLOUDINARY_ALLOWED_TYPES=image/jpeg,image/png,image/webp,image/gif
